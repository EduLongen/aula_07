# Copie este arquivo para .env e preencha os valores antes de rodar a aplicação.
# O arquivo .env NUNCA deve ser commitado no repositório.

# Chave secreta para assinar tokens JWT (mínimo 32 caracteres / 256 bits)
JWT_SECRET=troque-por-uma-chave-secreta-longa-e-aleatoria-256bits

# Tempo de expiração do JWT (access token) em milissegundos (padrão: 86400000 = 24h)
JWT_EXPIRATION=86400000

# Tempo de expiração do refresh token em milissegundos (padrão: 604800000 = 7 dias)
JWT_REFRESH_EXPIRATION=604800000

# Intervalo do job de limpeza de refresh tokens expirados em ms (padrão: 86400000 = 24h)
JWT_REFRESH_CLEANUP_INTERVAL=86400000

# Credenciais do banco PostgreSQL
DB_USERNAME=postgres
DB_PASSWORD=troque-pela-senha-do-banco
